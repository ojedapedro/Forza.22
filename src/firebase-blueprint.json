{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Super Usuario", "Administrador", "Auditor", "Presidencia"] },
        "avatar": { "type": "string" },
        "storeIds": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Tax or service payment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "storeName": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "specificType": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pendiente", "Aprobado", "Rechazado", "Vencido", "Cargado"] },
        "receiptUrl": { "type": "string" },
        "notes": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "submittedDate": { "type": "string", "format": "date-time" },
        "history": {
          "type": "array",
          "items": { "$ref": "AuditLog" }
        },
        "originalBudget": { "type": "number" },
        "isOverBudget": { "type": "boolean" },
        "documentDate": { "type": "string" },
        "documentAmount": { "type": "number" },
        "documentName": { "type": "string" }
      },
      "required": ["id", "storeId", "userId", "category", "amount", "dueDate", "status", "submittedDate"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Audit trail entry",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "action": { "type": "string", "enum": ["CREACION", "APROBACION", "RECHAZO", "ACTUALIZACION", "CORRECCION"] },
        "actorName": { "type": "string" },
        "role": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["date", "action", "actorName", "role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "nationality": { "type": "string" },
        "name": { "type": "string" },
        "lastName": { "type": "string" },
        "age": { "type": "number" },
        "educationLevel": { "type": "string" },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "positionDescription": { "type": "string" },
        "hireDate": { "type": "string" },
        "socialBenefitsDate": { "type": "string" },
        "projectedExitDate": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "projectAddress": { "type": "string" },
        "directPhone": { "type": "string" },
        "emergencyPhone": { "type": "string" },
        "homeAddress": { "type": "string" },
        "gender": { "type": "string" },
        "wearsGlasses": { "type": "string" },
        "hasCondition": { "type": "string" },
        "height": { "type": "string" },
        "storeId": { "type": "string" },
        "baseSalary": { "type": "number" },
        "isActive": { "type": "boolean" },
        "bankAccount": { "type": "string" },
        "ppeAssignments": {
          "type": "array",
          "items": { "$ref": "PPEAssignment" }
        }
      },
      "required": ["id", "name", "lastName", "storeId", "baseSalary", "isActive"]
    },
    "PPEAssignment": {
      "title": "PPEAssignment",
      "description": "Industrial safety equipment assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": { "$ref": "PPEItemData" }
        },
        "totalCost": { "type": "number" }
      },
      "required": ["id", "date", "items", "totalCost"]
    },
    "PPEItemData": {
      "title": "PPEItemData",
      "description": "Individual PPE item details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "talla": { "type": "string" },
        "cantidad": { "type": "number" },
        "precio": { "type": "number" },
        "frecuencia": { "type": "string" }
      },
      "required": ["name", "cantidad", "precio"]
    },
    "PayrollEntry": {
      "title": "PayrollEntry",
      "description": "Monthly payroll record for an employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeName": { "type": "string" },
        "employeeId": { "type": "string" },
        "storeId": { "type": "string" },
        "month": { "type": "string" },
        "baseSalary": { "type": "number" },
        "totalWorkerNet": { "type": "number" },
        "totalEmployerCost": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDIENTE", "PROCESADO"] },
        "submittedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "employeeId", "storeId", "month", "baseSalary", "status", "submittedDate"]
    },
    "ExchangeRate": {
      "title": "ExchangeRate",
      "description": "Historical exchange rate",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "rate": { "type": "number" }
      },
      "required": ["date", "rate"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "exchangeRate": { "type": "number" },
        "whatsappEnabled": { "type": "boolean" },
        "emailEnabled": { "type": "boolean" },
        "notificationPhone": { "type": "string" },
        "notificationEmail": { "type": "string" }
      }
    },
    "BudgetEntry": {
      "title": "BudgetEntry",
      "description": "Individual budget allocation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "date", "title", "amount", "category"]
    },
    "Store": {
      "title": "Store",
      "description": "Store location and management details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "municipality": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["En Regla", "En Riesgo", "Vencido"] },
        "nextDeadline": { "type": "string" },
        "matrixId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "required": ["id", "name", "address", "municipality"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer details for invoicing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rif": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "name", "rif", "email"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Electronic invoice record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientRif": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "taxAmount": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Borrador", "Enviada", "Pagada", "Anulada"] },
        "currency": { "type": "string", "enum": ["USD", "BS"] },
        "exchangeRate": { "type": "number" },
        "storeId": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "number", "issueDate", "clientId", "total", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Internal chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "system"] },
        "room": { "type": "string" }
      },
      "required": ["id", "senderId", "senderName", "text", "timestamp", "type", "room"]
    }
  },
  "firestore": {
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Historical chat messages"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Employee records"
    },
    "/payroll/{payrollId}": {
      "schema": "PayrollEntry",
      "description": "Payroll history"
    },
    "/exchange_rates/{date}": {
      "schema": "ExchangeRate",
      "description": "Historical exchange rates"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global settings"
    },
    "/budgets/{budgetId}": {
      "schema": "BudgetEntry",
      "description": "Budget entries"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store locations"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Customer database for invoices"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Sales invoices"
    }
  }
}
