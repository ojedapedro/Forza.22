rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == "analistadedatosnova@gmail.com" ||
         firestore.get(/databases/defaultforza22/documents/users/$(request.auth.uid)).data.role in ["Super Usuario", "Administrador"]);
    }

    match /payroll/finance/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }

    match /payments/{paymentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }
    
    match /employees/{employeeId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    match /users/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
